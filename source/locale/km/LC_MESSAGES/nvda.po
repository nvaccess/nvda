msgstr "бһ”бһ„бҹ’бһ бһ¶бһүбһҖбһ¶бһҡбһ–бҹ’бһҡбһҳбһ¶бһ“бһҮбһ¶бһ“бһ·бһ…бҹ’бһ… бһ“бҹ…бһ–бҹҒбһӣбһ”бһҫбһҖбһ•бҹ’бһ‘бһ¶бҹҶбһ„бһ”бһ¶бҹҶбһ„бһўбҹҒбһҖбҹ’бһҡбһ„бҹӢ"

#. Translators: Warning message when trying to enable the screen curtain when OCR is active.
#: screenCurtain\_screenCurtain.py:35
msgctxt "screenCurtain"
msgid "Cannot enable screen curtain while performing content recognition"
msgstr "бһҳбһ·бһ“бһўбһ¶бһ…бһ”бһҫбһҖбһ•бҹ’бһ‘бһ¶бҹҶбһ„бһ”бһ¶бҹҶбһ„бһўбҹҒбһҖбҹ’бһҡбһ„бҹӢбһ”бһ¶бһ“бһ‘бҹҒ бһҒбһҺбҹҲбһ–бҹҒбһӣбһҠбҹӮбһӣбһҖбҹҶбһ–бһ»бһ„бһўбһ“бһ»бһңбһҸбҹ’бһҸбһҖбһ¶бһҡбһ‘бһ‘бһҪбһӣбһҹбҹ’бһӮбһ¶бһӣбҹӢбһҳбһ¶бһҸбһ·бһҖбһ¶"

#. Translators: Reported when the screen curtain could not be enabled.
#: screenCurtain\_screenCurtain.py:39
msgid "Could not enable screen curtain"
msgstr "бһҳбһ·бһ“бһўбһ¶бһ…бһ”бһҫбһҖбһ•бҹ’бһ‘бһ¶бҹҶбһ„бһ”бһ¶бҹҶбһ„бһўбҹҒбһҖбҹ’бһҡбһ„бҹӢбһ”бһ¶бһ“бһ‘бҹҒ"

#. Translators: Explanation shown when screen curtain is enabled in the user's configuration,
#. but it failed to activate at NVDA startup
#: screenCurtain\_screenCurtain.py:45
msgctxt "screenCurtain"
msgid "There was a problem enabling Screen Curtain. The contents of your screen are still visible. You may attempt to enable Screen Curtain manually."
msgstr "бһҳбһ¶бһ“бһ”бһүбҹ’бһ бһ¶бһҖбҹ’бһ“бһ»бһ„бһҖбһ¶бһҡбһ”бһҫбһҖбһ•бҹ’бһ‘бһ¶бҹҶбһ„бһ”бһ¶бҹҶбһ„бһўбҹҒбһҖбҹ’бһҡбһ„бҹӢбҹ” бһҳбһ¶бһҸбһ·бһҖбһ¶бһ“бҹғбһўбҹҒбһҖбҹ’бһҡбһ„бҹӢбһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖбһ“бҹ…бһҸбҹӮбһўбһ¶бһ…бһҳбһҫбһӣбһғбһҫбһүбҹ” бһўбҹ’бһ“бһҖбһўбһ¶бһ…бһ–бҹ’бһҷбһ¶бһҷбһ¶бһҳбһ”бһҫбһҖбһ•бҹ’бһ‘бһ¶бҹҶбһ„бһ”бһ¶бҹҶбһ„бһўбҹҒбһҖбҹ’бһҡбһ„бҹӢбһҠбҹ„бһҷбһҒбҹ’бһӣбһҪбһ“бһўбҹ’бһ“бһҖбһ•бҹ’бһ‘бһ¶бһӣбҹӢбҹ”"

#. Translators: A warning shown when activating the screen curtain.
#. the translation of "Screen Curtain" should match the "translated name"
#: screenCurtain\_screenCurtain.py:74
msgid "Enabling Screen Curtain will make the screen of your computer completely black. Ensure you will be able to navigate without any use of your screen before continuing. \n\n"
"Do you wish to continue?"
msgstr "бһҖбһ¶бһҡбһ”бһҫбһҖбһ•бҹ’бһ‘бһ¶бҹҶбһ„бһ”бһ¶бҹҶбһ„бһўбҹҒбһҖбҹ’бһҡбһ„бҹӢ бһ“бһ№бһ„бһ’бҹ’бһңбһҫбһІбҹ’бһҷбһўбҹҒбһҖбҹ’бһҡбһ„бҹӢбһҖбһ»бҹҶбһ–бҹ’бһҷбһјбһ‘бҹҗбһҡбһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖбһ”бҹ’бһҡбҹӮбһ‘бҹ…бһҮбһ¶бһ„бһ„бһ№бһҸбһ‘бһ¶бҹҶбһ„бһҹбҹ’бһҡбһ»бһ„бҹ” бһҹбһјбһҳбһ”бҹ’бһҡбһ¶бһҖбһҠбһҗбһ¶ бһўбҹ’бһ“бһҖбһўбһ¶бһ…бһҡбһ»бһҖбһҡбһҖ бһ“бһ·бһ„бһ”бҹ’бһҡбһҫбһ”бҹ’бһҡбһ¶бһҹбҹӢбһҖбһ»бҹҶбһ–бҹ’бһҷбһјбһ‘бҹҗбһҡбһ”бһ¶бһ“ бһҠбҹ„бһҷбһҳбһ·бһ“бһ…бһ¶бҹҶбһ”бһ¶бһ…бҹӢбһҳбһҫбһӣбһўбҹҒбһҖбҹ’бһҡбһ„бҹӢ бһҳбһ»бһ“бһ–бҹҒбһӣбһ”бһ“бҹ’бһҸбҹ”\n"
"бһҸбһҫбһўбҹ’бһ“бһҖбһ…бһ„бҹӢбһ”бһ“бҹ’бһҸбһ‘бҹҒ?"

#. Translators: Reported when the language of the text being read is not supported by the current synthesizer.
#: speech\languageHandling.py:43
#, python-brace-format
msgctxt "languageNotSupported"
msgid "{lang} (not supported)"
msgstr "{lang} (бһҳбһ·бһ“бһӮбһ¶бҹҶбһ‘бҹ’бһҡбһ‘бҹҒ)"

#. Translators: Name of the speech mode which disables speech output.
#: speech\speech.py:106
msgctxt "speechModes"
msgid "off"
msgstr "бһ”бһ·бһ‘"

#. Translators: Name of the speech mode which will cause NVDA to beep instead of speaking.
#: speech\speech.py:108
msgctxt "speechModes"
msgid "beeps"
msgstr "бһҹбҹҶбһЎбҹҒбһ„бһ”бҹҠбһёбһ”"

#. Translators: Name of the speech mode which causes NVDA to speak normally.
#: speech\speech.py:110
msgctxt "speechModes"
msgid "talk"
msgstr "бһўбһ¶бһ“бһҮбһ¶бһҹбҹҶбһЎбҹҒбһ„"

#. Translators: Name of the on-demand speech mode,
#. in which NVDA only speaks in response to commands that report content.
#: speech\speech.py:113
msgctxt "speechModes"
msgid "on-demand"
msgstr "бһҸбһ¶бһҳбһҖбһ¶бһҡбһҹбҹ’бһ“бһҫбһҹбһ»бҹҶ"

#. Translators: cap will be spoken before the given letter when it is capitalized.
#: speech\speech.py:413
#, python-format
msgid "cap %s"
msgstr "бһўбһҖбҹ’бһҹбһҡбһ’бҹҶ %s"

#. Translators: 'Normalized' will be spoken after the given letter when it is normalized.
#: speech\speech.py:420
#, python-format
msgid "%s normalized"
msgstr "%s бһ’бһҳбҹ’бһҳбһҸбһ¶"

#. Translators: This is spoken when the given line has no indentation.
#: speech\speech.py:1087
msgid "no indent"
msgstr "бһӮбҹ’бһҳбһ¶бһ“бһҖбһ¶бһҡбһ…бһјбһӣбһ”бһ“бҹ’бһ‘бһ¶бһҸбҹӢ"

#. Translators: This is spoken to indicate that some text is already selected.
#. 'selected' preceding text is intentional.
#. For example 'selected hello world'
#: speech\speech.py:1264
#, python-format
msgid "selected %s"
msgstr "бһ”бһ¶бһ“бһҮбҹ’бһҡбһҫбһҹбһҡбһҫбһҹ %s"

#. Translators: This is spoken to indicate what has been unselected. for example 'hello unselected'
#: speech\speech.py:1400
#, python-format
msgid "%s unselected"
msgstr "%s бһҳбһ·бһ“бһ”бһ¶бһ“бһҮбҹ’бһҡбһҫбһҹбһҡбһҫбһҹ"

#. Translators: This is spoken to indicate when the previous selection was removed and a new selection was made. for example 'hello world selected instead'
#: speech\speech.py:1407
#, python-format
msgid "%s selected instead"
msgstr "%s бһ”бһ¶бһ“бһҮбҹ’бһҡбһҫбһҹбһҡбһҫбһҹбһҮбҹҶбһ“бһҪбһҹ"

#. Translators: Reported when selection is removed.
#: speech\speech.py:1410
msgid "selection removed"
msgstr "бһ”бһ¶бһ“бһҷбһҖбһҖбһ¶бһҡбһҮбҹ’бһҡбһҫбһҹбһҡбһҫбһҹбһ…бҹҒбһү"

#. Translators: Speaks current row number (example output: row 3).
#: speech\speech.py:2103 speech\speech.py:3165
#, python-format
msgid "row %s"
msgstr "бһҮбһҪбһҡбһҠбҹҒбһҖ %s"

#. Translators: Speaks the row span added to the current row number (example output: through 5).
#: speech\speech.py:2107
#, python-brace-format
msgid "through {endRow}"
msgstr "бһҡбһ бһјбһҸбһҠбһӣбҹӢ {endRow}"

#. Translators: Speaks current column number (example output: column 3).
#: speech\speech.py:2123 speech\speech.py:3161
#, python-format
msgid "column %s"
msgstr "бһҮбһҪбһҡбһҲбһҡ %s"

#. Translators: Speaks the column span added to the current column number (example output: through 5).
#: speech\speech.py:2127
#, python-brace-format
msgid "through {endCol}"
msgstr "бһҡбһ бһјбһҸбһҠбһӣбҹӢ {endCol}"

#. Translators: Speaks the row and column span added to the current row and column numbers
#. (example output: through row 5 column 3).
#: speech\speech.py:2136
#, python-brace-format
msgid "through row {row} column {column}"
msgstr "бһҸбһ¶бһҳбһҡбһҷбҹҲбһҮбһҪбһҡбһҠбҹҒбһҖ {row} бһҮбһҪбһҡбһҲбһҡ {column}"

#. Translators: Speaks when there are further details/annotations that can be fetched manually.
#: speech\speech.py:2170
msgid "has details"
msgstr "бһҳбһ¶бһ“бһ–бҹҗбһҸбҹҢбһҳбһ¶бһ“бһӣбһҳбҹ’бһўбһ·бһҸ"

#. Translators: Speaks the item level in treeviews (example output: level 2).
#: speech\speech.py:2192
#, python-format
msgid "level %s"
msgstr "бһҖбһҳбҹ’бһҡбһ·бһҸ %s"

#. Translators: Main part of the compound string to speak number of columns and rows in a table
#. Example: If the reported compound string is "with 3 rows and 2 columns", {rowCountTranslation} will be
#. replaced by "3 rows" and {colCountTranslation} by "2 columns"
#: speech\speech.py:2216
#, python-brace-format
msgid "with {rowCountTranslation} and {colCountTranslation}"
msgstr "бһҮбһ¶бһҳбһҪбһҷ {rowCountTranslation} бһ“бһ·бһ„ {colCountTranslation}"

#. Translators: Speaks number of columns (example output: with 4 columns).
#: speech\speech.py:2222
#, python-format
msgid "with %s column"
msgid_plural "with %s columns"
msgstr[0] "бһҮбһ¶бһҳбһҪбһҷ %s бһҮбһҪбһҡбһҲбһҡ"

#. Translators: Speaks number of rows (example output: with 2 rows).
#: speech\speech.py:2225
#, python-format
msgid "with %s row"
msgid_plural "with %s rows"
msgstr[0] "бһҮбһ¶бһҳбһҪбһҷ %s бһҮбһҪбһҡбһҠбҹҒбһҖ"

#. Translators: Sub-part of the compound string to speak number of rows and columns in a table.
#. Example: If the full compound string is "table with 3 rwos and 2 columns", this substring is "3 rows".
#: speech\speech.py:2233
#, python-brace-format
msgid "{rowCount} row"
msgid_plural "{rowCount} rows"
msgstr[0] "{rowCount} бһҮбһҪбһҡбһҠбҹҒбһҖ"

#. Translators: Sub-part of the compound string to speak number of rows and columns in a table.
#. Example: If the full compound string is "table with 3 rwos and 2 columns", this substring is "2 columns".
#: speech\speech.py:2243
#, python-brace-format
msgid "{columnCount} column"
msgid_plural "{columnCount} columns"
msgstr[0] "{columnCount} column"

#. Translators: Number of items in a list (example output: list with 5 items).
#: speech\speech.py:2432
#, python-format
msgid "with %s item"
msgid_plural "with %s items"
msgstr[0] "бһҮбһ¶бһҳбһҪбһҷ %s бһ’бһ¶бһҸбһ»"

#. Translators: Indicates end of something (example output: at the end of a list, speaks out of list).
#: speech\speech.py:2576 speech\speech.py:3034
#, python-format
msgid "out of %s"
msgstr "бһ…бҹҒбһүбһ–бһё %s"

#. Translators: Indicates the page number in a document.
#. %s will be replaced with the page number.
#: speech\speech.py:2644
#, python-format
msgid "page %s"
msgstr "бһ‘бҹҶбһ–бҹҗбһҡ %s"

#. Translators: Indicates the section number in a document.
#. %s will be replaced with the section number.
#: speech\speech.py:2651
#, python-format
msgid "section %s"
msgstr "бһ•бҹ’бһ“бҹӮбһҖ %s"

#. Translators: Indicates the text column number in a document.
#. {0} will be replaced with the text column number.
#. {1} will be replaced with the number of text columns.
#: speech\speech.py:2671
#, python-brace-format
msgid "column {0} of {1}"
msgstr "бһҮбһҪбһҡбһҲбһҡ {0} бһ“бҹғ {1}"

#. Translators: Indicates the text column number in a document.
#. %s will be replaced with the number of text columns.
#: speech\speech.py:2676
#, python-format
msgid "%s column"
msgid_plural "%s columns"
msgstr[0] "%s бһҮбһҪбһҡбһҲбһҡ"

#. Translators: Indicates the text column number in a document.
#: speech\speech.py:2680
#, python-brace-format
msgid "column {columnNumber}"
msgstr "бһҮбһҪбһҡбһҲбһҡ {columnNumber}"

#: speech\speech.py:2686
msgid "continuous section break"
msgstr "бһҖбһ¶бһҡбһ”бҹҶбһ”бҹӮбһҖбһ•бҹ’бһ“бҹӮбһҖбһ”бһ“бҹ’бһҸ"

#: speech\speech.py:2688
msgid "new column section break"
msgstr "бһҖбһ¶бһҡбһ”бҹҶбһ”бҹӮбһҖбһ•бҹ’бһ“бҹӮбһҖбһҮбһҪбһҡбһҲбһҡбһҗбҹ’бһҳбһё"

#: speech\speech.py:2690
msgid "new page section break"
msgstr "бһҖбһ¶бһҡбһ”бҹҶбһ”бҹӮбһҖбһ•бҹ’бһ“бҹӮбһҖбһ‘бҹҶбһ–бҹҗбһҡбһҗбҹ’бһҳбһё"

#: speech\speech.py:2692
msgid "even pages section break"
msgstr "бһҖбһ¶бһҡбһ”бҹҶбһ”бҹӮбһҖбһ•бҹ’бһ“бҹӮбһҖбһ‘бҹҶбһ–бҹҗбһҡбһӮбһј"

#: speech\speech.py:2694
msgid "odd pages section break"
msgstr "бһҖбһ¶бһҡбһ”бҹҶбһ”бҹӮбһҖбһ•бҹ’бһ“бҹӮбһҖбһ‘бҹҶбһ–бҹҗбһҡбһҹбҹҒбһҹ"

#: speech\speech.py:2700
msgid "column break"
msgstr "бһҖбһ¶бһҡбһ”бҹҶбһ”бҹӮбһҖбһҮбһҪбһҡбһҲбһҡ"

#. Translators: Speaks the heading level (example output: heading level 2).
#: speech\speech.py:2715
#, python-format
msgid "heading level %d"
msgstr "бһ…бҹҶбһҺбһ„бһҮбһҫбһ„бһҖбһҳбҹ’бһҡбһ·бһҸ %d"

#. Translators: Indicates the style of text.
#. A style is a collection of formatting settings and depends on the application.
#. %s will be replaced with the name of the style.
#: speech\speech.py:2738
#, python-format
msgid "style %s"
msgstr "бһҡбһ…бһ“бһ¶бһ”бҹҗбһ‘бҹ’бһҳ %s"

#. Translators: Indicates that text has reverted to the default style.
#. A style is a collection of formatting settings and depends on the application.
#: speech\speech.py:2742
msgid "default style"
msgstr "бһҡбһ…бһ“бһ¶бһ”бҹҗбһ‘бҹ’бһҳбһӣбҹҶбһ“бһ¶бҹҶбһҠбһҫбһҳ"

#. Translators: Indicates that cell does not have border lines.
#: speech\speech.py:2752
msgid "no border lines"
msgstr "бһӮбҹ’бһҳбһ¶бһ“бһ”бһ“бҹ’бһ‘бһ¶бһҸбҹӢбһҹбҹҠбһ»бһҳ"

#. Translators: Reported when there are two background colors.
#. This occurs when, for example, a gradient pattern is applied to a spreadsheet cell.
#. {color1} will be replaced with the first background color.
#. {color2} will be replaced with the second background color.
#: speech\speech.py:2783
#, python-brace-format
msgid "{color1} to {color2}"
msgstr "{color1} бһ‘бҹ…бһҠбһӣбҹӢ {color2}"

#. Translators: Reported when both the text and background colors change.
#. {color} will be replaced with the text color.
#. {backgroundColor} will be replaced with the background color.
#: speech\speech.py:2789
#, python-brace-format
msgid "{color} on {backgroundColor}"
msgstr "{color} бһ“бҹ…бһӣбһҫ {backgroundColor}"

#. Translators: Reported when the text color changes (but not the background color).
#. {color} will be replaced with the text color.
#: speech\speech.py:2797
#, python-brace-format
msgid "{color}"
msgstr "{color}"

#. Translators: Reported when the background color changes (but not the text color).
#. {backgroundColor} will be replaced with the background color.
#: speech\speech.py:2801
#, python-brace-format
msgid "{backgroundColor} background"
msgstr "{backgroundColor} бһ•бҹ’бһ‘бҹғбһҒбһ¶бһ„бһҖбҹ’бһҡбҹ„бһҷ"

#: speech\speech.py:2811
#, python-brace-format
msgid "background pattern {pattern}"
msgstr "бһӣбҹҶбһ“бһ¶бҹҶбһ•бҹ’бһ‘бҹғбһҒбһ¶бһ„бһҖбҹ’бһҡбҹ„бһҷ {pattern}"

#. Translators: Indicates the line number of the text.
#. %s will be replaced with the line number.
#: speech\speech.py:2818
#, python-format
msgid "line %s"
msgstr "бһҮбһҪбһҡ %s"

#. Translators: Reported when text is no longer marked as having been inserted.
#: speech\speech.py:2830
msgid "not inserted"
msgstr "бһҳбһ·бһ“бһ”бһ¶бһ“бһ”бһүбҹ’бһ…бһјбһӣбһ‘бҹҒ"

#. Translators: Reported when text is no longer marked as having been  deleted.
#: speech\speech.py:2841
msgid "not deleted"
msgstr "бһҳбһ·бһ“бһ”бһ¶бһ“бһӣбһ»бһ”бһ…бҹ„бһӣбһ‘бҹҒ"

#. Translators: Reported when text is revised.
#: speech\speech.py:2849
#, python-format
msgid "revised %s"
msgstr "бһҖбҹӮбһҸбһҳбҹ’бһҡбһјбһң %s"

#. Translators: Reported when text is not revised.
#: speech\speech.py:2852
#, python-format
msgid "no revised %s"
msgstr "бһӮбҹ’бһҳбһ¶бһ“бһҖбһ¶бһҡбһҖбҹӮбһҸбһҳбҹ’бһҡбһјбһңбһ‘бҹҒ %s"

#. Translators: Reported when text is marked
#: speech\speech.py:2861
msgid "marked"
msgstr "бһ”бһ¶бһ“бһҹбһҳбҹ’бһӮбһ¶бһӣбҹӢ"

#. Translators: Reported when text is no longer marked
#: speech\speech.py:2864
msgid "not marked"
msgstr "бһҳбһ·бһ“бһ”бһ¶бһ“бһҹбһҳбҹ’бһӮбһ¶бһӣбҹӢбһ‘бҹҒ"

#. Translators: Reported when text is color-highlighted
#: speech\speech.py:2874
