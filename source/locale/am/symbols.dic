complexSymbols:
# identifier	regexp
# Sentence endings.
። sentence ending	(?<=[^\s።])\።(?=[\"'”’)\s]|$)
! sentence ending	(?<=[^\s!])\!(?=[\"'”’)\s]|$)
? sentence ending	(?<=[^\s?])\?(?=[\"'”’)\s]|$)
¡ sentence ending	(?<=[^\s¡])\¡(?=[\"'”’)\s]|$)
# Phrase endings.
፤ phrase ending	(?<=[^\s፤])፤(?=\s|$)
፦ phrase ending	(?<=[^\s፦])፦(?=\s|$)
# Series of dots used for visual presentation, e.g. in table of contents
multiple .	\.{4,}

symbols:
# identifier	replacement[[	level][	preserve]][	# display name]

# Complex symbols
። sentence ending	አራት ነጥብ	all	always
! sentence ending	የቃል አጋንኖ ምልክት	all	always
? sentence ending	የጥያቄ ምልክት	all	always
¡ sentence ending	የሥላቅ ምልክት	all	always
፤ phrase ending	ድርብ ሠረዝ	most	always
፦ phrase ending	ችረት	most	always
multiple .	ቅጥልጥል ነጥቦች	all	always

# Standard punctuation/symbols
።	አራት ነጥብ	all	always
፤	ድርብ ሠረዝ	most	always
፦	ችረት	most	always
