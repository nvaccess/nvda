{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "tag:nvaccess.org,2026:nvda.config.archive.manifest.schema.json",
	"type": "object",
	"properties": {
		"formatVersion": {
			"type": "number",
			"minimum": 1,
			"maximum": 1
		},
		"createdAt": {
			"type": "string",
			"format": "date-time"
		},
		"nvdaVersion": {
			"type": "string",
			"pattern": "^(\\d+\\.){3}\\d+$"
		},
		"configSchemaVersion": {
			"type": "number",
			"minimum": 0
		}
	},
	"required": [
		"formatVersion",
		"createdAt",
		"nvdaVersion",
		"configSchemaVersion"
	]
}
